generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  username                String                   @unique
  role                    UserRole                 @default(USER)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  emailVerifiedAt         DateTime?
  isEmailVerified         Boolean                  @default(false)
  firstName               String
  lastName                String
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  payments                Payment[]
  predictions             Prediction[]
  tournamentParticipants  TournamentParticipant[]
}

model Tournament {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  startsAt               DateTime
  endsAt                 DateTime?
  prizePoolEntryDeadline DateTime
  entryFee               Decimal                 @db.Decimal(10, 2)
  currency               String                  @default("UAH")
  isPrizePoolEnabled     Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  matches                Match[]
  payments               Payment[]
  predictions            Prediction[]
  teams                  Team[]
  participants           TournamentParticipant[]
}

model TournamentParticipant {
  id            String          @id @default(cuid())
  userId        String
  tournamentId  String
  type          ParticipantType @default(FREE)
  joinedAt      DateTime        @default(now())
  paidAt        DateTime?
  paymentStatus PaymentStatus   @default(UNPAID)
  prizeEligible Boolean         @default(false)
  updatedAt     DateTime        @updatedAt
  tournament    Tournament      @relation(fields: [tournamentId], references: [id])
  user          User            @relation(fields: [userId], references: [id])

  @@unique([userId, tournamentId])
  @@index([tournamentId])
  @@index([prizeEligible])
}

model Team {
  id           String     @id @default(cuid())
  name         String
  externalId   Int?       @unique
  code         String?
  logoUrl      String?
  groupName    String?
  tournamentId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  awayMatches  Match[]    @relation("AwayTeam")
  homeMatches  Match[]    @relation("HomeTeam")
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([externalId, tournamentId])
  @@index([tournamentId, groupName])
}

model Match {
  id                 String       @id @default(cuid())
  tournamentId       String
  homeTeamId         String?
  awayTeamId         String?
  externalFixtureId  Int?
  startsAt           DateTime
  status             MatchStatus  @default(SCHEDULED)
  stage              MatchStage
  groupName          String?
  venueName          String?
  city               String?
  homeScore          Int?
  awayScore          Int?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  awayExtraTimeScore Int?
  awayPenaltyScore   Int?
  homeExtraTimeScore Int?
  homePenaltyScore   Int?
  elapsed            Int?
  awayTeam           Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam           Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  tournament         Tournament   @relation(fields: [tournamentId], references: [id])
  predictions        Prediction[]

  @@unique([externalFixtureId, tournamentId])
  @@index([tournamentId])
  @@index([startsAt])
  @@index([status])
}

model Prediction {
  id           String     @id @default(cuid())
  userId       String
  matchId      String
  tournamentId String
  homeScore    Int
  awayScore    Int
  confirmedAt  DateTime   @default(now())
  points       Decimal?   @db.Decimal(5, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  calculatedAt DateTime?
  match        Match      @relation(fields: [matchId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, matchId])
  @@index([tournamentId])
  @@index([matchId])
}

model Payment {
  id           String          @id @default(cuid())
  userId       String
  tournamentId String
  amount       Decimal         @db.Decimal(10, 2)
  currency     String          @default("UAH")
  provider     PaymentProvider @default(MONOBANK)
  status       PaymentStatus   @default(PENDING)
  invoiceId    String?
  paymentUrl   String?
  paidAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tournament   Tournament      @relation(fields: [tournamentId], references: [id])
  user         User            @relation(fields: [userId], references: [id])

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([tournamentId])
  @@index([status])
  @@index([invoiceId])
}

enum UserRole {
  USER
  ADMIN
}

enum ParticipantType {
  FREE
  PAID
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum PaymentProvider {
  MONOBANK
}
